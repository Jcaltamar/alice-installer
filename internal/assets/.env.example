# Alice Guardian Environment Variables
# Generated by alice-installer — do not commit .env
# Template version: 2026-04-18

# Node Environment
NODE_ENV=production

# Database Configuration
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
# SECURITY: POSTGRES_PASSWORD is generated by alice-installer at first-run using
# crypto/rand (32 bytes, base64). The example value has been intentionally blanked.
# If you are using a legacy deployment, rotate your password immediately.
POSTGRES_PASSWORD=
POSTGRES_DATABASE=alice_guardian
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
POSTGRES_IMAGE=postgres:11

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_IMAGE uses docker hub multi-arch manifest (no arch suffix needed)
REDIS_IMAGE=redis:7-alpine

# Queue Configuration
QUEUE_PORT=3000

# Backend Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=9090

# WebSocket Configuration
WEBSOCKET_HOST=127.0.0.1
WEBSOCKET_PORT=4550

# Web Interface Port
WEB_PORT=8080

# RTSP/Media Ports
RTSP_PORT=8554
RTMP_PORT=1935
HLS_PORT=8888
HLS_PORT2=8889
HLS_PORT3=8890

# External Services
TELEGRAM_API=http://127.0.0.1:9190
HOST_MQTT=127.0.0.1
HOST_MQTT_USER=ebenezer
HOST_MQTT_PWD=ebenezer
WORKSPACE=alice
APIFACE=http://127.0.0.1:18080
HOSTDOCKER=http://127.0.0.1
PORTDOCKER=2375
HOST_RTSP=127.0.0.1:8554

# Service Image Tags
# arch-agnostic defaults — alice-installer substitutes the correct arch tag at install time.
BACKEND_IMAGE=jcaltamare/aliceguardian:backend
WEBSOCKET_IMAGE=jcaltamare/aliceguardian:socket1
WEB_IMAGE=jcaltamare/aliceguardian:web_ag
QUEUE_IMAGE=jcaltamare/aliceguardian:queue

# Volume Directory
DOCKER_VOLUME_DIRECTORY=/opt/guardian

# Milvus Configuration
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
ETCD_ENDPOINTS=127.0.0.1:2379
MINIO_ADDRESS=127.0.0.1:9000
MILVUS_PORT=19530
MILVUS_WEB_PORT=9091
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000
